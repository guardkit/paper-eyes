{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HMRC CH2 — Child Benefit claim extraction",
  "type": "object",
  "additionalProperties": false,
  "required": ["claimant", "children"],
  "properties": {
    "claimant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "first_names",
        "last_name",
        "full_name",
        "nino",
        "date_of_birth",
        "address_lines",
        "postcode"
      ],
      "properties": {
        "title": { "type": "string" },
        "first_names": { "type": "string" },
        "last_name": { "type": "string" },
        "full_name": { "type": "string" },
        "nino": { "type": "string" },
        "date_of_birth": { "type": "string" },
        "address_lines": { "type": "array", "items": { "type": "string" } },
        "postcode": { "type": "string" }
      }
    },
    "children": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["first_names", "last_name", "full_name", "date_of_birth"],
        "properties": {
          "first_names": { "type": "string" },
          "last_name": { "type": "string" },
          "full_name": { "type": "string" },
          "date_of_birth": { "type": "string" }
        }
      }
    }
  }
}
