  "type": "object",
  "additionalProperties": false,
  "required": ["applicant"],
  "properties": {
    "applicant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["full_name", "reference"],
      "properties": {
        "full_name": { "type": "string" },
        "reference": { "type": "string" }
      }
    }
  }
}
